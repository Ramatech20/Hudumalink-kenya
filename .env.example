# App Configuration
NODE_ENV=production
APP_URL=https://your-app-name.render.com
PORT=3000

# Firebase Client Configuration (for frontend)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=(default)

# Firebase Configuration (for backend)
# Base64 encoded JSON of your service account key
FIREBASE_SERVICE_ACCOUNT=

# IntaSend Payment Integration
INTASEND_PUBLIC_KEY=
INTASEND_SECRET_KEY=
INTASEND_ENVIRONMENT=sandbox

# Notification Channels (SMTP & Twilio)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@hudumalinks.co.ke
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=


