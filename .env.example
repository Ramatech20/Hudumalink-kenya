# App Configuration
NODE_ENV=production
APP_URL=https://your-app-name.render.com
PORT=3000

# Firebase Client Configuration (for frontend)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=(default)

# Firebase Configuration (for backend)
# Base64 encoded JSON of your service account key
FIREBASE_SERVICE_ACCOUNT=

# M-Pesa Daraja API (Sandbox)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
MPESA_B2C_INITIATOR_NAME=
MPESA_B2C_SECURITY_CREDENTIAL=
MPESA_B2C_SHORTCODE=
MPESA_CALLBACK_TOKEN=your_secure_callback_token_here

# Notification Channels (SMTP & Twilio)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@hudumalinks.co.ke
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Pesapal API 3.0 Integration
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_ENVIRONMENT=sandbox
WEBHOOK_DOMAIN=https://us-central1-your-project.cloudfunctions.net
PAYMENT_CALLBACK_URL=https://hudumalink.co.ke/payment-callback

