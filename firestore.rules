rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Shared Helper Functions
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'ramadhanwambia83@gmail.com' ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          ('role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      ); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // ===============================================================
    // Entity Schema Validators
    // ===============================================================

     function isValidUser(data) {
      return data.get('uid', request.auth.uid) == request.auth.uid &&
             (!('email' in data) || (data.email is string && data.email.size() <= 200)) &&
             (!('role' in data) || (data.role in ['customer', 'provider', 'seller', 'admin'])) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 200)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1500)) &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 50)) &&
             (!('isPhoneVerified' in data) || data.isPhoneVerified is bool) &&
             (!('isVerified' in data) || data.isVerified is bool) &&
             (!('emailVerified' in data) || data.emailVerified is bool) &&
             (!('referralCode' in data) || (data.referralCode is string && data.referralCode.size() <= 50)) &&
             (!('referredBy' in data) || (data.referredBy == null || data.referredBy is string)) &&
             (!('createdAt' in data) || (data.createdAt is string)) &&
             (!('updatedAt' in data) || (data.updatedAt is string)) &&
             (!('location' in data) || (data.location is map)) &&
             (!('dob' in data) || (data.dob is string)) &&
             (!('countyOfBirth' in data) || (data.countyOfBirth is string)) &&
             (!('residence' in data) || (data.residence is string)) &&
             (!('area' in data) || (data.area is string)) &&
             (!('gender' in data) || (data.gender is string)) &&
             (!('occupation' in data) || (data.occupation is string)) &&
             (!('isOnline' in data) || data.isOnline is bool) &&
             (!('lastSeen' in data) || (data.lastSeen is string)) &&
             (!('deviceFingerprint' in data) || (data.deviceFingerprint is string && data.deviceFingerprint.size() <= 256)) &&
             (!('maxSingleSpend' in data) || data.maxSingleSpend is number) &&
             (!('totalSpend' in data) || data.totalSpend is number) &&
             (!('escrowBalance' in data) || data.escrowBalance is number) &&
             (!('referralEarnings' in data) || data.referralEarnings is number) &&
             (!('completedPaymentsCount' in data) || data.completedPaymentsCount is number) &&
             (!('idNumber' in data) || (data.idNumber is string)) &&
             (!('isFlagged' in data) || data.isFlagged is bool) &&
             (!('flagReason' in data) || (data.flagReason is string)) &&
             (!('kycStatus' in data) || data.kycStatus in ['none', 'pending', 'verified', 'rejected']) &&
             (!('roleRequestStatus' in data) || data.roleRequestStatus in ['none', 'pending', 'approved', 'rejected']) &&
             (!('requestedRole' in data) || data.requestedRole in ['customer', 'provider', 'seller']) &&
             (!('roleRequestCreatedAt' in data) || (data.roleRequestCreatedAt is string)) &&
             (!('roleRequestProcessedAt' in data) || (data.roleRequestProcessedAt is string)) &&
             (!('needsOnboarding' in data) || data.needsOnboarding is bool) &&
             (!('isOnboardingCompleted' in data) || data.isOnboardingCompleted is bool);
    }

    function isValidListing(data) {
      return data.authorId == request.auth.uid &&
             data.title is string && data.title.size() <= 150 &&
             data.description is string && data.description.size() <= 5000 &&
             (!('price' in data) || data.price == null || (data.price is number && data.price >= 0)) &&
             (!('originalPrice' in data) || data.originalPrice == null || (data.originalPrice is number && data.originalPrice >= 0)) &&
             (!('offerText' in data) || data.offerText == null || data.offerText is string) &&
             (!('giftText' in data) || data.giftText == null || data.giftText is string) &&
             (!('isOffer' in data) || data.isOffer is bool) &&
             (!('offerExpiresAt' in data) || data.offerExpiresAt == null || data.offerExpiresAt is string) &&
             data.type in ['product', 'service'] &&
             data.category is string &&
             data.status in ['active', 'pending', 'sold', 'removed', 'flagged'] &&
             data.images is list && data.images.size() <= 10 &&
             (!('stock' in data) || data.stock == null || data.stock is number) &&
             (!('viewCount' in data) || data.viewCount is number) &&
             (!('createdAt' in data) || data.createdAt is string);
    }

    function isValidReview(data) {
      return data.authorId == request.auth.uid &&
             data.targetId is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             (!('comment' in data) || (data.comment is string && data.comment.size() <= 500));
    }

    function isValidDispute(data) {
      return data.transactionId is string &&
             data.raisedById == request.auth.uid &&
             data.reason is string && data.reason.size() <= 1000 &&
             data.status == 'open';
    }

    function isValidAppeal(data) {
      return data.userId == request.auth.uid &&
             data.reason is string && data.reason.size() <= 1000 &&
             data.status == 'pending';
    }

    // ===============================================================
    // Collection Match Blocks
    // ===============================================================

    match /users/{userId} {
      allow get: if (isOwner(userId) || isAdmin()) && isValidId(userId);
      allow list: if isSignedIn();
      allow create: if (isOwner(userId) && isValidUser(incoming()) && 
                    incoming().role != 'admin' && 
                    // No sneaky balances on create
                    (!('escrowBalance' in incoming()) || incoming().escrowBalance == 0) &&
                    (!('referralEarnings' in incoming()) || incoming().referralEarnings == 0)) || isAdmin();
      
      allow update: if (isSignedIn() && (
        (isOwner(userId) && (
          // Action: Profile/Auth Update (General Owner Updates)
          (isValidUser(incoming()) && 
           incoming().diff(existing()).affectedKeys().hasOnly([
             'uid', 'email', 'displayName', 'photoURL', 'phoneNumber', 
             'isPhoneVerified', 'location', 'dob', 'countyOfBirth', 
             'residence', 'area', 'gender', 'occupation', 'role', 
             'completedPaymentsCount', 'emailVerified', 'referralCode', 
             'referredBy', 'createdAt', 'updatedAt', 'isVerified', 
             'kycStatus', 'isOnline', 'lastSeen', 'deviceFingerprint',
             'maxSingleSpend', 'totalSpend', 'escrowBalance', 'pendingWithdrawalBalance', 'earnings',
             'idNumber', 'isFlagged', 'flagReason',
             'roleRequestStatus', 'requestedRole', 'roleRequestCreatedAt', 'roleRequestProcessedAt', 'needsOnboarding', 'isOnboardingCompleted'
           ]) &&
           (isAdmin() || existing().get('role', 'customer') == 'admin' || !('role' in incoming()) || incoming().role == existing().get('role', 'customer'))
          )
        )) || 
        // Action: Balance Update (allow any authentic user to modify)
        true
      ));
      allow delete: if isAdmin();

      match /kyc/data {
        allow get: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isVerified();
      }
    }

    match /users_public/{userId} {
      allow get: if isValidId(userId);
      allow list: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin() || (
        isSignedIn() &&
        incoming().diff(existing()).affectedKeys().hasOnly(['completedPaymentsCount', 'updatedAt'])
      );
    }

    match /listings/{listingId} {
      allow get: if isValidId(listingId) && (resource == null || existing().status in ['active', 'pending', 'sold'] || isOwner(existing().authorId) || isAdmin());
      allow list: if resource.data.status == 'active' || (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();
      
      allow create: if isSignedIn() && isValidId(listingId) && isValidListing(incoming()) && incoming().status == 'pending';
      allow update: if isValidId(listingId) && (isAdmin() || (isOwner(existing().authorId) && 
                       isValidListing(incoming()) && (
                         // Update details (not status)
                         (incoming().status == existing().status && 
                          incoming().diff(existing()).affectedKeys().hasOnly([
                            'title', 'description', 'price', 'originalPrice', 'offerText', 'giftText', 'isOffer', 'offerExpiresAt', 'category', 'images', 
                            'location', 'contact', 'deliveryInfo', 'tipEnabled', 
                            'stock', 'sizes', 'specifications', 'aiModerationResult', 
                            'createdAt'
                          ])) ||
                         // Mark as sold/removed
                         (incoming().status != existing().status && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
                       )
                     ) || (
                       // Allow anyone to update viewCount
                       incoming().diff(existing()).affectedKeys().hasOnly(['viewCount']) &&
                       incoming().viewCount == existing().viewCount + 1
                     ));
      allow delete: if isAdmin() || isOwner(existing().authorId);
    }

    match /reviews/{reviewId} {
      allow get: if isValidId(reviewId);
      allow list: if true;
      allow create: if isVerified() && isValidReview(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin() || isOwner(existing().authorId);
    }

    match /chats/{chatId} {
      allow get: if isValidId(chatId) && isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow list: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isValidId(chatId) && isSignedIn() && request.auth.uid in incoming().participants;
      allow update: if isValidId(chatId) && isSignedIn() && request.auth.uid in existing().participants && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt', 'unreadCount']);

      match /messages/{messageId} {
        allow get, list: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
        allow create: if isValidId(messageId) && isSignedIn() && incoming().senderId == request.auth.uid && 
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

     match /transactions/{transactionId} {
      allow get: if isValidId(transactionId) && isSignedIn() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid || 
        isAdmin()
      );
      
      // Enforce strict identity constraints on collection query listings to prevent cross-tenant data leaks and scrapers
      allow list: if isSignedIn() && (
        (resource.data.buyerId == request.auth.uid) || 
        (resource.data.sellerId == request.auth.uid) || 
        isAdmin()
      );
      
      allow create: if isVerified() && isValidId(transactionId) && 
                    incoming().buyerId == request.auth.uid && 
                    (incoming().status in ['pending', 'pending_payment']) && 
                    incoming().amount > 0 &&
                    (
                      // Promotion transaction bypasses listing price check
                      ('type' in incoming() && incoming().type == 'promotion') ||
                      // Standard transactions check price if listing exists
                      (!exists(/databases/$(database)/documents/listings/$(incoming().listingId)) ||
                       incoming().amount >= get(/databases/$(database)/documents/listings/$(incoming().listingId)).data.price)
                    );
      
      allow update: if isValidId(transactionId) && (
        isAdmin() || 
        (isSignedIn() && (
          // Buyer Actions
          (isOwner(existing().buyerId) && (
            // Action: Confirm delivery / Release funds
            ((incoming().status in ['completed', 'released'] || ('milestones' in incoming()) || ('escrowMilestones' in incoming())) && 
             existing().status in ['deposited', 'delivered', 'paid', 'pending', 'paid_escrow', 'pending_release', 'released'] && 
             incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'releasedAt', 'milestones', 'escrowMilestones'])) ||
            // Action: Cancel (Only before delivery)
            (incoming().status == 'cancelled' && existing().status in ['pending', 'pending_payment', 'paid'] && 
             incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'cancellationReason', 'cancelledBy'])) ||
            // Action: Raise Dispute
            (incoming().status == 'disputed' && existing().status in ['paid', 'deposited', 'delivered', 'paid_escrow', 'pending_release'] && 
               incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'disputeReason'])) ||
            // Action: Sandbox payment simulation fallback
            (incoming().status in ['deposited', 'paid_escrow'] && existing().status in ['pending', 'pending_payment'] && 
             incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'mpesaReceiptNumber', 'paymentIntentId']))
          )) ||
          // Seller Actions
          (isOwner(existing().sellerId) && (
            // Action: Mark as Delivered
            (incoming().status == 'delivered' && existing().status in ['paid', 'paid_escrow', 'deposited', 'pending', 'pending_payment'] && 
             incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'deliveredAt', 'deliveryMetadata', 'paymentRequested', 'paymentRequestedAt', 'paymentRequestProof', 'paymentRequestEvidenceUrl'])) ||
            // Action: Accept Cancellation (if pending)
            (incoming().status == 'cancelled' && existing().status in ['pending', 'pending_payment'] && 
             incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'cancelledBy', 'cancellationReason']))
          )) ||
          // General Details/Proof/Milestones/Review/Delivery updates (Shared by Buyer or Seller)
          ((request.auth.uid == existing().buyerId || request.auth.uid == existing().sellerId) && (
            incoming().diff(existing()).affectedKeys().hasOnly([
              'updatedAt', 'paymentRequested', 'paymentRequestedAt', 'paymentRequestProof', 'paymentRequestEvidenceUrl', 
              'delivery', 'deliveredAt', 'milestones', 'escrowMilestones', 
              'reviewSubmitted', 'reviewRating', 'reviewComment'
            ])
          ))
        ))
      );
    }

    match /disputes/{disputeId} {
      allow get: if isValidId(disputeId) && isSignedIn() && (
        resource.data.raisedById == request.auth.uid || 
        isAdmin() ||
        (exists(/databases/$(database)/documents/transactions/$(resource.data.transactionId)) && 
         get(/databases/$(database)/documents/transactions/$(resource.data.transactionId)).data.sellerId == request.auth.uid)
      );
      allow list: if isSignedIn() && (
        resource.data.raisedById == request.auth.uid || 
        isAdmin() ||
        (exists(/databases/$(database)/documents/transactions/$(resource.data.transactionId)) && 
         get(/databases/$(database)/documents/transactions/$(resource.data.transactionId)).data.sellerId == request.auth.uid)
      );
      allow create: if isSignedIn() &&
                    incoming().transactionId is string &&
                    incoming().raisedById == request.auth.uid &&
                    incoming().reason is string &&
                    incoming().status == 'open';
      allow update: if isAdmin() || (
        isSignedIn() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['sellerResponse', 'sellerEvidenceUrls', 'sellerRespondedAt', 'status'])
      );
    }

    match /notifications/{notificationId} {
      allow get: if isValidId(notificationId) && (isOwner(resource.data.userId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow delete: if isValidId(notificationId) && isOwner(resource.data.userId);
      allow update: if isValidId(notificationId) && isOwner(resource.data.userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow create: if isSignedIn();
    }

    match /withdrawals/{withdrawalId} {
      allow get: if isValidId(withdrawalId) && (isOwner(resource.data.userId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isVerified() && isValidId(withdrawalId) && incoming().userId == request.auth.uid && incoming().status == 'pending';
      allow update: if isValidId(withdrawalId) && isAdmin();
    }

    match /appeals/{appealId} {
      allow get: if isValidId(appealId) && (isOwner(resource.data.userId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isVerified() && isValidId(appealId) && isValidAppeal(incoming());
      allow update: if isAdmin();
    }

    match /promotions/{promotionId} {
      allow get: if isValidId(promotionId) && (isOwner(resource.data.userId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isVerified() && isValidId(promotionId) && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /referral_codes/{code} {
      allow read: if true;
      allow create: if isOwner(incoming().userId);
      allow update: if isOwner(existing().userId) && isOwner(incoming().userId);
      allow delete: if isAdmin();
    }
    
    match /phone_registry/{phone} {
      allow get: if phone.size() <= 32;
      allow list: if isAdmin();
      allow create: if isSignedIn() && phone.size() <= 32 && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && phone.size() <= 32 && (existing().userId == request.auth.uid || isAdmin());
    }
    
    match /hold_ledgers/{ledgerId} {
      allow get: if isValidId(ledgerId) && (isOwner(resource.data.userId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && isValidId(ledgerId) && (
        incoming().userId == request.auth.uid ||
        (
          exists(/databases/$(database)/documents/transactions/$(incoming().transactionId)) &&
          get(/databases/$(database)/documents/transactions/$(incoming().transactionId)).data.buyerId == request.auth.uid
        )
      );
      allow update: if isAdmin() || (
        isSignedIn() && isValidId(ledgerId) && isOwner(existing().userId) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'unlockedAt'])
      );
      allow delete: if isAdmin();
    }

    match /dashboard_transaction_logs/{logId} {
      allow get: if isValidId(logId) && (isOwner(resource.data.userId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create, update, delete: if false;
    }
    
    match /reports/{reportId} {
      allow get: if isValidId(reportId) && (isSignedIn() && (resource.data.reporterId == request.auth.uid || isAdmin()));
      allow list: if isSignedIn() && (resource.data.reporterId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().reporterId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow get: if isValidId(ticketId) && (isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid));
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
