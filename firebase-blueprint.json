{
  "entities": {
    "ReferralCode": {
      "title": "ReferralCode",
      "description": "A mapping from a referral code to a user ID",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user of the platform (Customer, Provider, or Seller)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "provider", "seller", "admin"] },
        "location": {
          "type": "object",
          "properties": {
            "county": { "type": "string" },
            "town": { "type": "string" }
          }
        },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "cancellationCount": { "type": "number" },
        "isFlagged": { "type": "boolean" },
        "flagReason": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "isOnline": { "type": "boolean" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Listing": {
      "title": "Listing",
      "description": "A service or product listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number", "description": "Original price for discount calculations (was/now)" },
        "offerText": { "type": "string", "description": "Promotion discount, deal, or offer text" },
        "giftText": { "type": "string", "description": "Description of free gift included with purchase" },
        "type": { "type": "string", "enum": ["service", "product"] },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "location": {
          "type": "object",
          "properties": {
            "county": { "type": "string" },
            "town": { "type": "string" }
          }
        },
        "contact": {
          "type": "object",
          "properties": {
            "phone": { "type": "string" },
            "whatsapp": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["active", "pending", "sold", "removed"] },
        "isPromoted": { "type": "boolean" },
        "promotionTier": { "type": "string", "enum": ["basic", "premium", "elite"] },
        "featuredUntil": { "type": "string", "format": "date-time" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "viewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "title", "type", "category", "status"]
    },
    "Promotion": {
      "title": "Promotion",
      "description": "A record of a listing promotion payment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "listingId": { "type": "string" },
        "userId": { "type": "string" },
        "tier": { "type": "string", "enum": ["basic", "premium", "elite"] },
        "amount": { "type": "number" },
        "durationDays": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "expired"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["listingId", "userId", "tier", "amount", "durationDays", "status", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A review for a user or listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "targetId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "targetId", "rating"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between two users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text"]
    },
    "UserKYC": {
      "title": "UserKYC",
      "description": "Sensitive identity verification data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "idType": { "type": "string" },
        "idNumber": { "type": "string" },
        "idFrontUrl": { "type": "string" },
        "idBackUrl": { "type": "string" },
        "selfieUrl": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "rejectionReason": { "type": "string" }
      },
      "required": ["uid", "idType", "idNumber", "idFrontUrl", "selfieUrl", "submittedAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "An escrow transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "listingId": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "deposited", "disputed", "completed", "released", "cancelled"] },
        "checkoutRequestId": { "type": "string" },
        "cancellationReason": { "type": "string" },
        "cancelledBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["listingId", "buyerId", "sellerId", "amount", "status"]
    },
    "Dispute": {
      "title": "Dispute",
      "description": "A dispute over a transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "transactionId": { "type": "string" },
        "raisedById": { "type": "string" },
        "reason": { "type": "string" },
        "details": { "type": "string" },
        "evidenceUrls": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["open", "under_review", "resolved", "refunded"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["transactionId", "raisedById", "reason", "status"]
    },
    "WithdrawalRequest": {
      "title": "WithdrawalRequest",
      "description": "A request to withdraw funds",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string", "enum": ["mpesa", "bank"] },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "method", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error", "message", "request"] },
        "read": { "type": "boolean" },
        "link": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    },
    "Appeal": {
      "title": "Appeal",
      "description": "An appeal for a flagged account",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "reason", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/kyc/data": {
      "schema": "UserKYC",
      "description": "Sensitive KYC data"
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "Marketplace listings"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "User and listing reviews"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Escrow transactions"
    },
    "/disputes/{disputeId}": {
      "schema": "Dispute",
      "description": "Transaction disputes"
    },
    "/withdrawals/{withdrawalId}": {
      "schema": "WithdrawalRequest",
      "description": "Withdrawal requests"
    },
    "/appeals/{appealId}": {
      "schema": "Appeal",
      "description": "Account appeals"
    },
    "/promotions/{promotionId}": {
      "schema": "Promotion",
      "description": "Promotion payment records"
    },
    "/referral_codes/{code}": {
      "schema": "ReferralCode",
      "description": "Mapping of referral codes to user IDs"
    }
  }
}
