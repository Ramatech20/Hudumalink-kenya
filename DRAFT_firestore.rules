rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Shared Helper Functions
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      ); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // ===============================================================
    // Entity Schema Validators
    // ===============================================================

    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['customer', 'provider', 'seller', 'admin'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 50)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 20)) &&
             (!('escrowBalance' in data) || data.escrowBalance is number) &&
             (!('referralEarnings' in data) || data.referralEarnings is number) &&
             (!('kycStatus' in data) || data.kycStatus in ['none', 'pending', 'verified', 'rejected']);
    }

    function isValidListing(data) {
      return data.authorId == request.auth.uid &&
             data.title is string && data.title.size() <= 100 &&
             data.description is string && data.description.size() <= 2000 &&
             data.price is number && data.price >= 0 &&
             data.type in ['product', 'service'] &&
             data.category is string &&
             data.status in ['active', 'pending', 'sold', 'removed'] &&
             data.images is list && data.images.size() <= 8;
    }

    function isValidReview(data) {
      return data.authorId == request.auth.uid &&
             data.targetId is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             (!('comment' in data) || (data.comment is string && data.comment.size() <= 500));
    }

    function isValidDispute(data) {
      return data.transactionId is string &&
             data.raisedById == request.auth.uid &&
             data.reason is string && data.reason.size() <= 1000 &&
             data.status == 'open';
    }

    function isValidAppeal(data) {
      return data.userId == request.auth.uid &&
             data.reason is string && data.reason.size() <= 1000 &&
             data.status == 'pending';
    }

    // ===============================================================
    // Collection Match Blocks
    // ===============================================================

    match /users/{userId} {
      allow get: if (isOwner(userId) || isAdmin()) && isValidId(userId);
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().role != 'admin' && 
                    // No sneaky balances on create
                    (!('escrowBalance' in incoming()) || incoming().escrowBalance == 0) &&
                    (!('referralEarnings' in incoming()) || incoming().referralEarnings == 0);
      
      allow update: if (isOwner(userId) && (
        // Action: Update Profile Info
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber', 'location', 'dob', 'countyOfBirth', 'residence', 'area', 'gender', 'occupation']) && isValidUser(incoming())) ||
        // Action: Role Upgrade (Consent to become provider/seller)
        (existing().role == 'customer' && incoming().diff(existing()).affectedKeys().hasOnly(['role']) && incoming().role in ['provider', 'seller']) ||
        // Action: Role Downgrade (Give up being provider)
        (existing().role != 'customer' && incoming().diff(existing()).affectedKeys().hasOnly(['role']) && incoming().role == 'customer')
      )) || isAdmin();

      match /kyc/data {
        allow get: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isVerified();
      }
    }

    match /users_public/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn();
      allow create, update: if isOwner(userId) || isAdmin();
    }

    match /listings/{listingId} {
      allow get: if isValidId(listingId) && (existing().status == 'active' || isOwner(existing().authorId) || isAdmin());
      allow list: if resource.data.status == 'active' || (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();
      
      allow create: if isVerified() && isValidId(listingId) && isValidListing(incoming()) && incoming().status == 'pending';
      allow update: if isValidId(listingId) && (isAdmin() || (isOwner(existing().authorId) && 
                       isValidListing(incoming()) && (
                         // Update details (not status)
                         (incoming().status == existing().status && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'category', 'images', 'location', 'contact', 'deliveryInfo', 'tipEnabled'])) ||
                         // Mark as sold
                         (existing().status == 'active' && incoming().status == 'sold' && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
                         // Hide/Remove
                         (incoming().status == 'removed' && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
                       )
                     ) || (
                       // Allow system/others to update viewCount/reportsCount if needed
                       incoming().diff(existing()).affectedKeys().hasOnly(['viewCount', 'reportsCount'])
                     ));
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow get: if isValidId(reviewId);
      allow list: if true;
      allow create: if isVerified() && isValidReview(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin() || isOwner(existing().authorId);
    }

    match /chats/{chatId} {
      allow get: if isValidId(chatId) && isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow list: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isValidId(chatId) && isSignedIn() && request.auth.uid in incoming().participants;
      allow update: if isValidId(chatId) && isSignedIn() && request.auth.uid in existing().participants && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt']);

      match /messages/{messageId} {
        allow get, list: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
        allow create: if isValidId(messageId) && isSignedIn() && incoming().senderId == request.auth.uid && 
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    match /transactions/{transactionId} {
      allow get: if isValidId(transactionId) && isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAdmin());
      
      allow create: if isVerified() && isValidId(transactionId) && incoming().buyerId == request.auth.uid && incoming().status == 'pending';
      allow update: if isValidId(transactionId) && (isAdmin() || (isOwner(existing().buyerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'cancellationReason', 'cancelledBy'])));
    }

    match /disputes/{disputeId} {
      allow get: if isValidId(disputeId) && isSignedIn() && (resource.data.raisedById == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.raisedById == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidId(disputeId) && isValidDispute(incoming());
      allow update: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow get: if isValidId(notificationId) && (isOwner(resource.data.userId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow delete: if isValidId(notificationId) && isOwner(resource.data.userId);
      allow update: if isValidId(notificationId) && isOwner(resource.data.userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow create: if isSignedIn();
    }

    match /withdrawals/{withdrawalId} {
      allow get: if isValidId(withdrawalId) && (isOwner(resource.data.userId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isVerified() && isValidId(withdrawalId) && incoming().userId == request.auth.uid && incoming().status == 'pending';
      allow update: if isValidId(withdrawalId) && isAdmin();
    }

    match /appeals/{appealId} {
      allow get: if isValidId(appealId) && (isOwner(resource.data.userId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isVerified() && isValidId(appealId) && isValidAppeal(incoming());
      allow update: if isAdmin();
    }

    match /promotions/{promotionId} {
      allow get: if isValidId(promotionId) && (isOwner(resource.data.userId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isVerified() && isValidId(promotionId) && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /referral_codes/{code} {
      allow read: if true;
      allow create: if isOwner(incoming().userId);
    }
    
    match /reports/{reportId} {
      allow get: if isValidId(reportId) && (isSignedIn() && (resource.data.reporterId == request.auth.uid || isAdmin()));
      allow list: if isSignedIn() && (resource.data.reporterId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().reporterId == request.auth.uid;
      allow update: if isAdmin();
    }
  }
}
